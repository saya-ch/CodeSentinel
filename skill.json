{
  "name": "CodeSentinel",
  "version": "1.0.0",
  "displayName": "🔒 CodeSentinel - AI代码安全卫士",
  "description": "智能检测AI生成代码的安全漏洞，包括SQL注入、XSS、硬编码凭证等常见威胁，基于OWASP Top 10标准",
  "author": {
    "name": "saya-ch",
    "github": "https://github.com/saya-ch"
  },
  "tags": [
    "安全",
    "代码审计",
    "漏洞检测",
    "AI编程辅助",
    "OWASP",
    "网络安全"
  ],
  "categories": [
    "开发工具",
    "安全审计",
    "代码质量"
  ],
  "languages": [
    "Python",
    "JavaScript",
    "TypeScript"
  ],
  "license": "MIT",
  "repository": "https://github.com/saya-ch/CodeSentinel",
  "homepage": "https://github.com/saya-ch/CodeSentinel#readme",
  "issues": "https://github.com/saya-ch/CodeSentinel/issues",
  "created": "2026-05-18",
  "updated": "2026-05-18",
  "compatibility": {
    "trae": ">=1.0.0"
  },
  "detectionRules": {
    "sql_injection": {
      "severity": "critical",
      "cvss": 9.8,
      "patterns": [
        "f\"SELECT",
        "f\"INSERT",
        "f\"UPDATE",
        "f\"DELETE",
        "execute(\"",
        "query % "
      ]
    },
    "command_injection": {
      "severity": "critical",
      "cvss": 9.1,
      "patterns": [
        "os.system(",
        "subprocess.*shell=True",
        "eval(",
        "exec("
      ]
    },
    "hardcoded_credentials": {
      "severity": "critical",
      "cvss": 8.5,
      "patterns": [
        "API_KEY = \"sk-",
        "password = \"",
        "SECRET",
        "TOKEN"
      ]
    },
    "xss": {
      "severity": "high",
      "cvss": 8.1,
      "patterns": [
        "innerHTML =",
        "dangerouslySetInnerHTML",
        "document.write("
      ]
    },
    "insecure_deserialization": {
      "severity": "high",
      "cvss": 8.1,
      "patterns": [
        "pickle.loads(",
        "yaml.load(",
        "Marshal.loads("
      ]
    },
    "path_traversal": {
      "severity": "high",
      "cvss": 7.5,
      "patterns": [
        "open(path",
        "readFile(",
        "readFileSync("
      ]
    },
    "weak_crypto": {
      "severity": "medium",
      "cvss": 5.3,
      "patterns": [
        "hashlib.md5(",
        "hashlib.sha1(",
        "Crypto.Cipher.DES"
      ]
    },
    "sensitive_data_exposure": {
      "severity": "medium",
      "cvss": 4.2,
      "patterns": [
        "print.*password",
        "console.log.*token",
        "logging.*secret"
      ]
    }
  }
}
